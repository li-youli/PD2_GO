#include <stdio.h>
#include <stdlib.h>

typedef struct NODE{
int val;
struct NODE *next;
}NODE;

NODE *head = NULL;

void insertFirst(int val){
NODE *newNode = (NODE*) malloc(sizeof(NODE));
newNode->val = val;
newNode->next = head;
head = newNode;
}

void deleteFirst(){
NODE *temp = head;
if(temp == NULL){
printf("NULL LIST\n");
};
head = head->next;
free(temp);
}

void insertTail(int val){
NODE *newNode = (NODE*) malloc(sizeof(NODE));
newNode->val = val;
newNode->next = NULL;

if(head == NULL){
head = newNode;
return;
}

NODE *temp = head;
while(temp->next != NULL){
temp = temp->next;
}

temp->next = newNode;
};

void printall(){
