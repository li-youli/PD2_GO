printf("%d ",head->val);
printf("\n");
head = head->next;
}
}

void insertInto(int val,int pos){
    NODE* newNode = (NODE*) malloc(sizeof(NODE));
    newNode->val = val;
    if(pos == 0){
        newNode->next = head;
        head = newNode;
        return;
    }

    NODE* temp = head;
    for(int i = 0; i < pos-1;i++){
        if(temp == NULL){
            printf("invalid");
            return;
        }
        temp = temp->next;
    }

    if(temp == NULL){
        printf("invalid");
        return;
    }

    newNode->next = temp->next;
    temp->next = newNode;

}

